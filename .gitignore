# Local terraform files
.terraform/
.terraform.lock.hcl

# State files — these live in your remote backend, not Git
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Plan files — contain sensitive data
tfdev
tfprod
*.tfplan

# Vars files — may contain secrets/passwords
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.jsonkeys/
keys/